#include <FastLED.h>
#include <LiquidCrystal_I2C.h>
#include <DFRobotDFPlayerMini.h>
#include <SoftwareSerial.h>

#define NUM_LEDS 81
#define LED_PIN 9
#define BRIGHTNESS 100
#define LED_TYPE WS2812B
#define COLOR_ORDER GRB

CRGB leds[NUM_LEDS];

// Button pins
#define BTN_UP     2
#define BTN_DOWN   3
#define BTN_LEFT   5
#define BTN_RIGHT  6
#define BTN_SWITCH 7

enum GameMode { MENU, GUITAR, SNAKE, VOLUME_ADJUST };
GameMode gameMode = MENU;

// ---------------- GRID ----------------
const int WIDTH = 9;
const int HEIGHT = 9;

// ---------------- HIGH SCORES ----------------
int highScoreSlayer = 0;
int highScoreSnake  = 0;

// ---------------- SNAKE ----------------
int snake[81];
int snakeLength = 3;
int direction = 1;
int nextDirection = 1;
int headRow = 4;
int headCol = 4;
int food = 40;

// ---------------- PIXEL SLAYER ----------------
#define NUM_GAME_COLS 5
int gameCols[NUM_GAME_COLS] = {2,3,4,5,6};
int buttonPins[NUM_GAME_COLS] = {2,3,5,6,7};

CRGB laneColors[NUM_GAME_COLS] = {
  CRGB::Blue, CRGB::Red, CRGB::Green, CRGB::White, CRGB::Yellow
};

int tileY[NUM_GAME_COLS] = {-3,-3,-3,-3,-3};
int tileLength[NUM_GAME_COLS] = {0,0,0,0,0};
bool tileActive[NUM_GAME_COLS] = {false};
bool segmentHit[NUM_GAME_COLS][NUM_ROWS] = {false};

unsigned long lastFallTime = 0;
int fallDelay = 250;
int score = 0;

unsigned long gameStartTime = 0;
unsigned long currentGameDuration = 168000;

// Per-song durations
unsigned long songDurations[] = {
  168000, // Paranoid
  158000, // I Just Threw Out the Man of My Dreams
  294000, // Like A Stone
  219000  // Come As You Are
};

// Scoring
#define SCORE_TAP 100
#define SCORE_HOLD 300
#define SCORE_MISS 50

LiquidCrystal_I2C lcd(0x27,16,2);

// ---------------- DFPLAYER ----------------
SoftwareSerial dfSerial(11, 10);
DFRobotDFPlayerMini dfplayer;

// ---------------- SONG SELECTION ----------------
enum Song { PARANOID=1, I_JUST_THREW_OUT, LIKE_A_STONE, COME_AS_YOU_ARE };
Song selectedSong = PARANOID;
bool inSongMenu = false;

const char* songNames[] = {
  "Paranoid",
  "I Just Threw Out the Man of My Dreams",
  "Like A Stone",
  "Come As You Are"
};

unsigned long lastNameScroll = 0;
int nameScrollIndex = 0;
const int LCD_NAME_WIDTH = 14;
const unsigned long NAME_SCROLL_DELAY = 400;

// ---------------- UTILITY ----------------
int indexFromColRow(int col,int row) {
  return (col % 2 == 0) ? col * NUM_ROWS + row
                        : col * NUM_ROWS + (NUM_ROWS - 1 - row);
}

int XY(int x,int y) {
  return (y % 2 == 0) ? y * WIDTH + x
                      : y * WIDTH + (WIDTH - 1 - x);
}

void updateScoreLCD(int highScore) {
  lcd.setCursor(0,0);
  lcd.print("Score:");
  lcd.print(score);
  lcd.print("    ");

  lcd.setCursor(0,1);
  lcd.print("High :");
  lcd.print(highScore);
  lcd.print("    ");
}

// ---------------- MENU ----------------
void showMenu() {
  gameMode = MENU;
  inSongMenu = false;
  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("Select Game");
  lcd.setCursor(0,1);
  lcd.print("1:Slayer 2:Snake");
}

void menuAnimation() {
  static uint8_t hue = 0;
  for(int i=0;i<NUM_LEDS;i++)
    leds[i] = CHSV((hue+i*3)%255,255,100);
  hue++;
  FastLED.show();
}

// ---------------- SONG MENU ----------------
void showSongMenu() {
  inSongMenu = true;
  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("Select Song:");
  nameScrollIndex = 0;
  lastNameScroll = millis();
}

void updateSongNameDisplay() {
  const char* name = songNames[selectedSong - 1];
  int len = strlen(name);

  lcd.setCursor(0,1);
  lcd.print("> ");

  if(len <= LCD_NAME_WIDTH){
    lcd.print(name);
    for(int i=len;i<LCD_NAME_WIDTH;i++) lcd.print(" ");
    return;
  }

  if(millis() - lastNameScroll >= NAME_SCROLL_DELAY){
    lastNameScroll = millis();
    nameScrollIndex++;
    if(nameScrollIndex > len) nameScrollIndex = 0;
  }

  for(int i=0;i<LCD_NAME_WIDTH;i++){
    int idx = nameScrollIndex + i;
    lcd.print(idx >= len ? ' ' : name[idx]);
  }
}

void scrollSongMenu() {
  static unsigned long lastInput = 0;
  if(millis() - lastInput < 200) return;

  if(digitalRead(BTN_DOWN) == LOW){
    selectedSong = (Song)(selectedSong - 1);
    if(selectedSong < PARANOID) selectedSong = COME_AS_YOU_ARE;
    nameScrollIndex = 0;
    lastInput = millis();
  }

  if(digitalRead(BTN_RIGHT) == LOW){
    selectedSong = (Song)(selectedSong + 1);
    if(selectedSong > COME_AS_YOU_ARE) selectedSong = PARANOID;
    nameScrollIndex = 0;
    lastInput = millis();
  }

  if(digitalRead(BTN_LEFT) == LOW){
    inSongMenu = false;
    startGame(GUITAR);
    dfplayer.play((int)selectedSong);
    return;
  }

  updateSongNameDisplay();
}

// ---------------- VOLUME ADJUST ----------------
int currentVolume = 10; // Default DFPlayer volume
const int MAX_VOLUME = 30;
const int MIN_VOLUME = 0;

void showVolumeMenu() {
  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("Adjust Volume:");
  lcd.setCursor(0,1);
  lcd.print("Vol: ");
  lcd.print(currentVolume);
}

void volumeAdjustLoop() {
  static unsigned long lastInput = 0;
  if(millis() - lastInput < 150) return;

  // Volume up (pin 6)
  if(digitalRead(BTN_RIGHT) == LOW){
    if(currentVolume < MAX_VOLUME) currentVolume++;
    dfplayer.volume(currentVolume);
    lcd.setCursor(5,1);
    lcd.print("   "); // Clear previous
    lcd.setCursor(5,1);
    lcd.print(currentVolume);
    lastInput = millis();
  }

  // Volume down (pin 3)
  if(digitalRead(BTN_DOWN) == LOW){
    if(currentVolume > MIN_VOLUME) currentVolume--;
    dfplayer.volume(currentVolume);
    lcd.setCursor(5,1);
    lcd.print("   ");
    lcd.setCursor(5,1);
    lcd.print(currentVolume);
    lastInput = millis();
  }

  // Confirm volume (pin 5)
  if(digitalRead(BTN_LEFT) == LOW){
    showMenu();
    lastInput = millis();
  }
}

// ---------------- PIXEL SLAYER ----------------
void moveTilesDown() {
  for(int i=0;i<NUM_GAME_COLS;i++){
    if(tileActive[i]){
      tileY[i]++;
      if(tileY[i]-tileLength[i]+1 > NUM_ROWS-1){
        tileActive[i]=false;
        tileY[i]=-3;
        tileLength[i]=0;
        for(int r=0;r<NUM_ROWS;r++) segmentHit[i][r]=false;
      }
    }
  }
}

void spawnTiles() {
  int col=random(NUM_GAME_COLS);
  if(!tileActive[col]){
    tileActive[col]=true;
    tileY[col]=-3;
    tileLength[col] = random(2)==0 ? 1 : 3;
    for(int r=0;r<NUM_ROWS;r++) segmentHit[col][r]=false;
  }
}

void drawTiles() {
  fill_solid(leds,NUM_LEDS,CRGB(128,0,128));
  for(int lane=0;lane<NUM_GAME_COLS;lane++){
    if(!tileActive[lane]) continue;
    for(int seg=0;seg<tileLength[lane];seg++){
      int row=tileY[lane]+seg;
      if(row>=0 && row<NUM_ROWS)
        leds[indexFromColRow(gameCols[lane],row)] = laneColors[lane];
    }
  }
  FastLED.show();
}

// ORIGINAL HIT DETECTION
void checkButtons() {
  for(int lane=0;lane<NUM_GAME_COLS;lane++){
    bool pressed = (digitalRead(buttonPins[lane]) == LOW);

    if(pressed && tileActive[lane]){
      for(int seg=0;seg<tileLength[lane];seg++){
        int row = tileY[lane] + seg;
        if(row == NUM_ROWS-1 && !segmentHit[lane][seg]){
          segmentHit[lane][seg] = true;
          leds[indexFromColRow(gameCols[lane], row)] = CRGB::Orange;
          FastLED.show();
          score += (tileLength[lane] > 1) ? SCORE_HOLD : SCORE_TAP;
          updateScoreLCD(highScoreSlayer);
        }
      }
    }

    if(pressed){
      bool hit=false;
      for(int seg=0;seg<tileLength[lane];seg++)
        if(tileY[lane]+seg==NUM_ROWS-1) hit=true;

      if(!hit){
        leds[indexFromColRow(gameCols[lane],NUM_ROWS-1)] = CRGB::Red;
        FastLED.show();
        delay(60);
        score = max(0, score - SCORE_MISS);
        updateScoreLCD(highScoreSlayer);
      }
    }
  }
}

void guitarLoop(){
  if(millis() - gameStartTime >= currentGameDuration){
    if(score > highScoreSlayer) highScoreSlayer = score;
    showMenu();
    return;
  }

  if(millis() - lastFallTime > fallDelay){
    lastFallTime = millis();
    moveTilesDown();
    spawnTiles();
    drawTiles();
    checkButtons();
  }
}

// ---------------- SNAKE ----------------
void spawnFood() {
  while(true){
    int f=random(NUM_LEDS);
    bool ok=true;
    for(int i=0;i<snakeLength;i++) if(snake[i]==f) ok=false;
    if(ok){ food=f; return; }
  }
}

void resetSnake() {
  if(score > highScoreSnake) highScoreSnake = score;
  score = 0;
  snakeLength=3;
  headRow=4; headCol=4;
  snake[0]=XY(4,4);
  snake[1]=XY(3,4);
  snake[2]=XY(2,4);
  direction=1; nextDirection=1;
  spawnFood();
  updateScoreLCD(highScoreSnake);
}

void readSnakeButtons() {
  int newDir=direction;
  if(digitalRead(BTN_UP)==LOW) newDir=0;
  if(digitalRead(BTN_RIGHT)==LOW) newDir=1;
  if(digitalRead(BTN_DOWN)==LOW) newDir=2;
  if(digitalRead(BTN_LEFT)==LOW) newDir=3;

  if(!((direction==0&&newDir==2)||(direction==2&&newDir==0)||
       (direction==1&&newDir==3)||(direction==3&&newDir==1)))
    nextDirection=newDir;
}

void snakeLoop(){
  if(digitalRead(BTN_SWITCH)==LOW){
    showMenu();
    return;
  }

  readSnakeButtons();
  direction=nextDirection;

  int dRow=0,dCol=0;
  if(direction==0)dRow=-1;
  if(direction==1)dCol=1;
  if(direction==2)dRow=1;
  if(direction==3)dCol=-1;

  int newRow=headRow+dRow;
  int newCol=headCol+dCol;

  if(newRow<0||newRow>=HEIGHT||newCol<0||newCol>=WIDTH){
    resetSnake(); return;
  }

  int newHead=XY(newCol,newRow);
  for(int i=0;i<snakeLength;i++)
    if(snake[i]==newHead){ resetSnake(); return; }

  for(int i=snakeLength;i>0;i--) snake[i]=snake[i-1];
  snake[0]=newHead;
  headRow=newRow; headCol=newCol;

  if(newHead==food){
    snakeLength++;
    score++;
    spawnFood();
    updateScoreLCD(highScoreSnake);
  }

  fill_solid(leds,NUM_LEDS,CRGB::Blue);
  leds[food]=CRGB::Red;
  leds[snake[0]]=CRGB::Green;
  for(int i=1;i<snakeLength;i++) leds[snake[i]]=CRGB::Yellow;
  FastLED.show();
  delay(300);
}

// ---------------- GAME CONTROL ----------------
void startGame(GameMode g){
  gameMode=g;
  score=0;
  lcd.clear();

  if(g==GUITAR){
    currentGameDuration = songDurations[selectedSong - 1];
    updateScoreLCD(highScoreSlayer);
    gameStartTime=millis();
  }
  if(g==SNAKE){
    updateScoreLCD(highScoreSnake);
    resetSnake();
  }
}

// ---------------- SETUP ----------------
void setup(){
  FastLED.addLeds<LED_TYPE,LED_PIN,COLOR_ORDER>(leds,NUM_LEDS);
  FastLED.setBrightness(BRIGHTNESS);
  FastLED.clear();
  FastLED.show();

  lcd.init();
  lcd.backlight();

  pinMode(BTN_UP,INPUT_PULLUP);
  pinMode(BTN_DOWN,INPUT_PULLUP);
  pinMode(BTN_LEFT,INPUT_PULLUP);
  pinMode(BTN_RIGHT,INPUT_PULLUP);
  pinMode(BTN_SWITCH,INPUT_PULLUP);

  dfSerial.begin(9600);
  dfplayer.begin(dfSerial);
  dfplayer.volume(currentVolume);

  showMenu();
}

// ---------------- LOOP ----------------
void loop(){
  if(gameMode==MENU){
    menuAnimation();
    
    // Enter volume adjust
    if(!inSongMenu && digitalRead(BTN_LEFT)==LOW){
      gameMode = VOLUME_ADJUST;
      showVolumeMenu();
      delay(200);
    }
    else if(!inSongMenu && digitalRead(BTN_UP)==LOW) showSongMenu();
    else if(inSongMenu) scrollSongMenu();
    else if(digitalRead(BTN_DOWN)==LOW) startGame(SNAKE);
  }
  else if(gameMode==VOLUME_ADJUST){
    volumeAdjustLoop();
  }
  else if(gameMode==GUITAR) guitarLoop();
  else if(gameMode==SNAKE)  snakeLoop();
}
